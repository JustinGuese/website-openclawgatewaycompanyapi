---
const pricing = [
	{ service: "Digital Invoice", price: "5.00 USDC", note: "via Lexoffice" },
	{ service: "Physical Letter", price: "3.00 USDC", note: "via Pingen (DE)" },
	{ service: "Fax (per page)", price: "1.00 USDC", note: "via Telnyx" },
	{ service: "GmbH Formation", price: "3,000 USDC", note: "Full service + HITL" },
	{ service: "UG Formation", price: "1,500 USDC", note: "+ Stammkapital" },
];
---

<div class="mt-12 overflow-hidden border border-slate-200 rounded-lg">
	<table class="min-w-full divide-y divide-slate-200">
		<thead class="bg-slate-50">
			<tr>
				<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Service</th>
				<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Price</th>
				<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Details</th>
			</tr>
		</thead>
		<tbody class="bg-white divide-y divide-slate-200">
			{pricing.map((item) => (
				<tr>
					<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">{item.service}</td>
					<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">{item.price}</td>
					<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">{item.note}</td>
				</tr>
			))}
		</tbody>
	</table>
</div>
