---
interface Props {
	title: string;
	description: string;
	price: string;
	href: string;
	icon?: string;
}

const { title, description, price, href } = Astro.props;
---

<div class="flex flex-col border border-slate-200 rounded-xl p-8 hover:shadow-lg transition-shadow bg-white">
	<h3 class="text-xl font-bold text-slate-900">{title}</h3>
	<p class="mt-4 text-slate-600 flex-grow">
		{description}
	</p>
	<div class="mt-8 flex items-center justify-between">
		<span class="text-sm font-semibold text-slate-500">Starts at <span class="text-slate-900">{price}</span></span>
		<a href={href} class="text-sm font-bold text-slate-900 hover:underline">Learn more &rarr;</a>
	</div>
</div>
