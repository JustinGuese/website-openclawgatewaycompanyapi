---
import Landing from '../../layouts/Landing.astro';

const posts = [
  {
    title: "GmbH remote gründen 2026 — Ein Leitfaden",
    description: "Wie Sie eine deutsche GmbH von überall auf der Welt gründen, ohne jemals Deutschland zu besuchen.",
    slug: "gmbh-remote-gruenden-2026",
    date: "2026-04-20"
  },
  {
    title: "Was ist das x402 Payment Protocol?",
    description: "Der neue Standard für Zahlungen zwischen KI-Agenten und APIs.",
    slug: "x402-payment-protocol-deutsch",
    date: "2026-04-15"
  },
  {
    title: "Stripe für AI Agents — Warum x402 die Zukunft ist",
    description: "Warum traditionelle Zahlungsanbieter für autonome Agenten nicht funktionieren.",
    slug: "stripe-fuer-ai-agents",
    date: "2026-04-10"
  }
];
---

<Landing title="Blog - AgentBureau">
  <div class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-slate-900 sm:text-5xl">
          AgentBureau Blog
        </h1>
        <p class="mt-4 text-xl text-slate-600">
          Insights into legal tech, AI agents, and on-chain infrastructure.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => (
          <div class="bg-white border border-slate-200 rounded-xl p-6 hover:shadow-md transition-shadow">
            <p class="text-sm text-slate-500 mb-2">{post.date}</p>
            <h2 class="text-xl font-bold text-slate-900 mb-3">{post.title}</h2>
            <p class="text-slate-600 mb-4">{post.description}</p>
            <a href={`/blog/${post.slug}`} class="text-slate-900 font-bold hover:underline">
              Weiterlesen &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</Landing>

