---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PaymentFlow from '../components/PaymentFlow.astro';
---

<Landing title="Legal infrastructure for AI agents in Germany">
	<Hero 
		title="Legal infrastructure for AI agents in Germany." 
		subtitle="Invoices, letters, fax, and GmbH formation — paid per call with USDC on Base. No accounts. No API keys. Humans in the loop where the law requires it."
	/>

	<section class="py-24 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-3xl font-extrabold text-slate-900">How it works</h2>
				<p class="mt-4 text-lg text-slate-600">The x402 payment protocol enables trustless, account-less API interactions.</p>
			</div>
			<PaymentFlow />
		</div>
	</section>

	<section class="py-24">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-extrabold text-slate-900">Our Services</h2>
				<p class="mt-4 text-lg text-slate-600">Bridging the gap between the digital and physical worlds in Germany.</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<ServiceCard 
					title="GmbH Formation" 
					description="Remote formation of a German GmbH, including notary coordination and bank account." 
					price="2,500 USDC" 
					href="/gmbh-gruenden"
				/>
				<ServiceCard 
					title="Invoice API" 
					description="Generate and send tax-compliant German invoices via Lexoffice automatically." 
					price="0.50 USDC" 
					href="/invoice-api"
				/>
				<ServiceCard 
					title="Fax API" 
					description="Send legally binding faxes to German authorities and businesses via Telnyx." 
					price="0.10 USDC" 
					href="/fax-api"
				/>
				<ServiceCard 
					title="Letter API" 
					description="Send physical letters within Germany via Pingen. Full tracking included." 
					price="1.20 USDC" 
					href="/letter-api"
				/>
			</div>
		</div>
	</section>

	<section class="py-24 bg-slate-900 text-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
				<div>
					<h2 class="text-3xl font-bold">Built for Agents</h2>
					<p class="mt-6 text-slate-300">
						AgentBureau is designed from the ground up for autonomous AI agents. We use the x402 protocol for payments, meaning your agent can manage its own budget and legal footprint without human intervention.
					</p>
					<div class="mt-8">
						<code class="block bg-slate-800 p-4 rounded-lg text-sm text-green-400 overflow-x-auto">
							curl -X POST https://agentbureau-api.datafortress.cloud/v1/fax/dry-run \<br/>
							&nbsp;&nbsp;-H "Idempotency-Key: $(uuidgen)"
						</code>
					</div>
				</div>
				<div class="bg-slate-800 p-8 rounded-xl border border-slate-700">
					<h3 class="text-xl font-bold">Why Base?</h3>
					<p class="mt-4 text-slate-300">
						Base provides the speed and low transaction costs required for micro-payments. USDC on Base is our native currency, ensuring stable pricing and instant settlement.
					</p>
					<ul class="mt-6 space-y-4">
						<li class="flex items-center">
							<svg class="h-6 w-6 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							<span>Sub-cent gas fees</span>
						</li>
						<li class="flex items-center">
							<svg class="h-6 w-6 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							<span>Instant confirmations</span>
						</li>
						<li class="flex items-center">
							<svg class="h-6 w-6 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							<span>Deep USDC liquidity</span>
						</li>
					</ul>
				</div>
			</div>
		</div>
	</section>
</Landing>

