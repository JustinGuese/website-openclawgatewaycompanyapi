---
import Landing from '../layouts/Landing.astro';
import { getLocaleFromUrl, useTranslations } from '../i18n/t';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<Landing title={t('contact.title')} description={t('contact.description')}>
  <div class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="text-4xl font-extrabold text-slate-900 sm:text-5xl">
          {t('contact.title')}
        </h1>
        <p class="mt-4 text-xl text-slate-600">
          {t('contact.subtitle')}
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        {/* Left Column: Traditional Contact Info */}
        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 shadow-sm h-full">
          <div class="space-y-8">
            <div>
              <h3 class="text-lg font-bold text-slate-900 mb-2">{t('contact.email.title')}</h3>
              <p class="text-slate-600 mb-4">
                {t('contact.email.desc')}
              </p>
              <div id="contact-container" class="inline-flex items-center space-x-2 text-indigo-600 font-medium hover:text-indigo-500 transition-colors">
                <span class="text-slate-400 italic text-sm">{t('contact.email.noJs')}</span>
              </div>
            </div>

            <div class="pt-8 border-t border-slate-200">
              <h3 class="text-lg font-bold text-slate-900 mb-2">{t('contact.phone.title')}</h3>
              <p class="text-slate-600 mb-4">
                {t('contact.phone.desc')}
              </p>
              <a href="tel:+16505820116" class="text-lg font-semibold text-indigo-600 underline decoration-2 underline-offset-4 hover:text-indigo-500 transition-colors">
                +1 650 582 0116
              </a>
            </div>

            <div class="pt-8 border-t border-slate-200">
              <h3 class="text-lg font-bold text-slate-900 mb-2">{t('contact.address.title')}</h3>
              <p class="text-slate-600">
                DataFortress.cloud GmbH<br />
                Gewerbestraße 13<br />
                82064 Straßlach-Dingharting<br />
                Germany
              </p>
            </div>
          </div>
        </div>

        {/* Right Column: Cal.com Embed */}
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden h-[1100px] flex flex-col">
          <div class="p-6 border-b border-slate-100 bg-slate-50">
             <h3 class="text-lg font-bold text-slate-900">{t('forInvestors.cta.secondary')}</h3>
             <p class="text-sm text-slate-500 mt-1">Select a time for a 30-min intro call</p>
          </div>
          <div class="flex-grow">
            <!-- Cal inline embed code begins -->
            <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-30min"></div>
            <script type="text/javascript" is:inline>
              (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
            Cal("init", "30min", {origin:"https://app.cal.com"});

              Cal.ns["30min"]("inline", {
                elementOrSelector:"#my-cal-inline-30min",
                config: {"layout":"week_view","useSlotsViewOnSmallScreen":"true"},
                calLink: "datafortress-justin/30min",
              });

              Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"week_view"});
            </script>
            <!-- Cal inline embed code ends -->
          </div>
        </div>
      </div>
    </div>
  </div>
</Landing>

<script is:inline>
  // Obfuscation to hide email from simple crawlers
  (function() {
    const user = "info";
    const domain = "agentbureau.de";
    const container = document.getElementById('contact-container');
    
    if (container) {
      const email = user + "@" + domain;
      const link = document.createElement('a');
      link.href = "mailto:" + email;
      link.textContent = email;
      link.className = "text-lg font-semibold underline decoration-2 underline-offset-4";
      
      container.innerHTML = '';
      container.appendChild(link);
    }
  })();
</script>
