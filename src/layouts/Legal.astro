---
import Landing from './Landing.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<Landing title={title}>
	<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
		<article class="prose prose-slate lg:prose-lg mx-auto">
			<h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">{title}</h1>
			<div class="mt-8">
				<slot />
			</div>
		</article>
	</div>
</Landing>

<style is:global>
	@reference "tailwindcss";

	.prose h2 {
		@apply text-2xl font-bold text-slate-900 mt-12 mb-4;
	}
	.prose p {
		@apply my-4 text-slate-600 leading-relaxed;
	}
	.prose ul {
		@apply list-disc list-inside my-4 text-slate-600;
	}
</style>
